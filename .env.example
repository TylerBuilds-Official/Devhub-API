# ──────────────────────────────────────────────────────────────────────────
# DevHub API — environment variables
# ──────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in local values. Do not commit .env.


# ── UpdateSuite upstream ─────────────────────────────────────────────────
# Base URL of UpdateSuiteAPI running on Tyler's workstation.
# Windows boot service, defaults to port 8765 per UPDATESUITE/api/main.py.
UPDATESUITE_BASE_URL=http://localhost:8765

# Per-call timeout (seconds) for httpx requests to the upstream.
UPDATESUITE_TIMEOUT=10.0


# ── Database ─────────────────────────────────────────────────────────────
# pyodbc connection string targeting TOOLBOX. dev_hub schema lives here.
# TrustServerCertificate is required for self-signed SQL Server certs.
DEVHUB_DB_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=TOOLBOX;Trusted_Connection=yes;TrustServerCertificate=yes;


# ── Health poller ────────────────────────────────────────────────────────
# Global default probe interval in seconds. Per-project overrides via
# health_interval_s in registry.json win over this value.
DEVHUB_HEALTH_INTERVAL_S=60


# ── Azure AD / MSAL auth ─────────────────────────────────────────────────
# Shared JobScan app registration. Frontend (dev-hub) drives interactive
# sign-in with MSAL.js and sends us the ID token (not the Graph access
# token — Graph access tokens use hashed-nonce signing and can't be
# validated by third parties). Backend only validates, never acquires.
AAD_TENANT_ID=99857259-7d6a-47fb-a35b-7f6004c4965d
AAD_CLIENT_ID=79633382-952d-4e11-bd6d-6f047bf5732b

# ID-token audience is the app registration's client id. Keep this in
# sync with AAD_CLIENT_ID above.
AAD_AUDIENCE=79633382-952d-4e11-bd6d-6f047bf5732b

# Tenant-scoped JWKS discovery endpoint. Keys cached in-process for ~1h.
AAD_JWKS_URL=https://login.microsoftonline.com/99857259-7d6a-47fb-a35b-7f6004c4965d/discovery/v2.0/keys


# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the SPA. Keep tight in
# prod; local dev is http://localhost:5174 (Vite default for dev-hub).
DEVHUB_ALLOWED_ORIGINS=http://localhost:5174
