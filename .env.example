# ──────────────────────────────────────────────────────────────────────────
# DevHub API — environment variables
# ──────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in local values. Do not commit .env.


# ── UpdateSuite upstream ─────────────────────────────────────────────────
# Base URL of UpdateSuiteAPI running on Tyler's workstation.
# Windows boot service, defaults to port 8765 per UPDATESUITE/api/main.py.
UPDATESUITE_BASE_URL=http://localhost:8765

# Per-call timeout (seconds) for httpx requests to the upstream.
UPDATESUITE_TIMEOUT=10.0


# ── Database ─────────────────────────────────────────────────────────────
# pyodbc connection string targeting TOOLBOX. dev_hub schema lives here.
# TrustServerCertificate is required for self-signed SQL Server certs.
DEVHUB_DB_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=TOOLBOX;Trusted_Connection=yes;TrustServerCertificate=yes;


# ── Health poller ────────────────────────────────────────────────────────
# Global default probe interval in seconds. Per-project overrides via
# health_interval_s in registry.json win over this value.
DEVHUB_HEALTH_INTERVAL_S=60
